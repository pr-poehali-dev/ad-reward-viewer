{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET without device_id returns 400",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400
    },
    {
      "name": "GET with device_id creates user",
      "method": "GET",
      "path": "/",
      "headers": { "X-Device-Id": "test-device-002" },
      "expectedStatus": 200
    }
  ]
}
